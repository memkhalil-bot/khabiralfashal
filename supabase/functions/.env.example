# Edge Function secrets — NOT Vite/frontend env vars.
#
# These are read only by Deno Edge Functions (e.g. create-checkout-session)
# via Deno.env.get(...). They are never bundled into the frontend and the
# Stripe secret key must never be exposed to the browser.
#
# Set real values with the Supabase CLI (do not commit a filled-in copy):
#   supabase secrets set --env-file supabase/functions/.env.local
# or via the Supabase Dashboard → Edge Functions → Secrets.

# Stripe secret key (server-side only, starts with sk_)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (server-side only, starts with whsec_).
# Used by stripe-webhook to verify the Stripe-Signature header. Get this
# value from the Stripe Dashboard (or `stripe listen`) when you configure
# the webhook endpoint after deploying the function.
STRIPE_WEBHOOK_SECRET=

# Default currency used when an invoice row has none set (lowercase ISO code)
STRIPE_CURRENCY=usd

# Public site origin used to build Stripe success/cancel redirect URLs
PUBLIC_SITE_URL=https://khabiralfashal.com

# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by the Supabase Edge Runtime — do not set them here.
